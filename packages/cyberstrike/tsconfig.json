{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "jsxImportSource": "@opentui/solid",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [],
    "noUncheckedIndexedAccess": false,
    "customConditions": [
      "browser"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@tui/*": [
        "./src/cli/cmd/tui/*"
      ]
    }
  }
}